{
  "manifest_version": 3,
  "name": "Human Typer",
  "version": "1.1.0",
  "description": "Intercepts paste events and replays them as realistic human typing with configurable speed and errors.",
  "permissions": ["activeTab", "scripting", "storage", "clipboardRead"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Human Typer"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
